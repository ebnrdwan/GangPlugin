{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gang Score Rubric",
  "description": "Scoring rubric definitions for each evaluation dimension",
  "type": "object",
  "properties": {
    "market_viability": { "$ref": "#/$defs/rubricDimension" },
    "user_desirability": { "$ref": "#/$defs/rubricDimension" },
    "technical_feasibility": { "$ref": "#/$defs/rubricDimension" },
    "financial_viability": { "$ref": "#/$defs/rubricDimension" },
    "strategic_alignment": { "$ref": "#/$defs/rubricDimension" },
    "domain_fit": { "$ref": "#/$defs/rubricDimension" }
  },
  "required": ["market_viability", "user_desirability", "technical_feasibility", "financial_viability", "strategic_alignment"],
  "additionalProperties": false,
  "$defs": {
    "rubricDimension": {
      "type": "object",
      "description": "Rubric levels for a scoring dimension. Keys are score levels (1, 3, 5, 7, 9, 10).",
      "properties": {
        "1":  { "type": "string", "minLength": 10 },
        "3":  { "type": "string", "minLength": 10 },
        "5":  { "type": "string", "minLength": 10 },
        "7":  { "type": "string", "minLength": 10 },
        "9":  { "type": "string", "minLength": 10 },
        "10": { "type": "string", "minLength": 10 }
      },
      "required": ["1", "3", "5", "7", "9", "10"],
      "additionalProperties": false
    }
  }
}
