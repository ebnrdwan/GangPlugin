{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gang Scorecard",
  "description": "Rubric-anchored, evidence-linked scoring for each plan dimension",
  "type": "object",
  "required": ["plan_name", "dimensions", "weighted_average", "overall_confidence"],
  "properties": {
    "plan_name": {
      "type": "string",
      "description": "Name of the plan being scored"
    },
    "dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dimension", "score", "rubric_anchor", "rubric_text", "evidence_ids", "assumption_ids", "justification", "confidence"],
        "properties": {
          "dimension": {
            "type": "string",
            "enum": [
              "market_viability", "user_desirability", "technical_feasibility",
              "financial_viability", "strategic_alignment", "domain_fit"
            ]
          },
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "rubric_anchor": {
            "type": "string",
            "description": "The rubric level this score maps to (e.g. '7')"
          },
          "rubric_text": {
            "type": "string",
            "description": "The rubric description for this level"
          },
          "evidence_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^ev-\\d{3,}$" },
            "description": "Evidence entries supporting this score"
          },
          "assumption_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^as-\\d{3,}$" },
            "description": "Assumptions this score depends on"
          },
          "justification": {
            "type": "string",
            "minLength": 20,
            "description": "Why this score was given"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence in this score (0.0-1.0)"
          }
        },
        "additionalProperties": false
      },
      "minItems": 5,
      "maxItems": 6
    },
    "weighted_average": {
      "type": "number",
      "minimum": 1,
      "maximum": 10
    },
    "overall_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": true
}
